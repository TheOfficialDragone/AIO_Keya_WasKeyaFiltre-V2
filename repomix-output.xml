// Utilise uniquement si IsDanfoss == 1
// -----------------------------------------------------------------------
static float    wasOffsetF   = 0.0f;
static uint32_t stableStart  = 0;

static const float    AUTOZERO_SPEED_MIN    = 4.0f;
static const float    AUTOZERO_YAWRATE_MAX  = 0.5f;
